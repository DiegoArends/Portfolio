---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const links = [
    { href: lang === 'es' ? '/' : `/${lang}/`, label: "Home" },
    { href: "#projects", label: t('nav.projects') },
    { href: "#experience", label: t('nav.experience') },
    { href: "#about", label: t('nav.about') },
];
---

<header class="sticky top-0 z-50 w-full backdrop-blur px-2">
    <div id="header-inner" class="mx-auto max-w-4xl flex flex-col items-center gap-2 py-3 transition-all duration-300 data-[scrolled=true]:mt-2 data-[scrolled=true]:rounded-2xl data-[scrolled=true]:border data-[scrolled=true]:border-neutral-800 data-[scrolled=true]:bg-neutral-950/70 data-[scrolled=true]:shadow-2xl">
        <nav class="flex items-center gap-4 sm:gap-6 flex-wrap justify-center px-4">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        aria-current={
                            currentPath === link.href ? "page" : undefined
                        }
                        class={`text-sm tracking-tight transition-colors hover:text-sky-300 ${
                            currentPath === link.href
                                ? "text-sky-400"
                                : "text-neutral-300"
                        }`}
                    >
                        {link.label}
                    </a>
                ))
            }
            <div id="lang-wrapper">
              <LanguagePicker />
            </div>
        </nav>
    </div>
</header>

<style>
  /* Ocultar selector de idioma en scroll (solo móvil) para ganar espacio */
  #header-inner[data-scrolled="true"] #lang-wrapper {
    display: none;
  }

  /* Mostrar siempre en escritorio */
  @media (min-width: 640px) {
    #header-inner[data-scrolled="true"] #lang-wrapper {
      display: block;
    }
  }
</style>

<script>
  const inner = document.getElementById('header-inner');
  const update = () => {
    if (!inner) return;
    if (window.scrollY > 10) {
      inner.setAttribute('data-scrolled', 'true');
    } else {
      inner.removeAttribute('data-scrolled');
    }
  };
  update();
  window.addEventListener('scroll', update, { passive: true });
</script>
