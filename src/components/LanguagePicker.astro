---
import { languages } from '../i18n/ui';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---
<div class="flex gap-1 items-center bg-neutral-900/40 px-1.5 py-1 rounded-xl border border-neutral-800/60 ml-4">
  {Object.entries(languages).map(([code, _]) => (
    <a
      href={code === 'es' ? '/' : `/${code}/`}
      class={`text-[9px] font-black px-2 py-1 rounded-lg transition-all uppercase tracking-tighter ${
        lang === code 
          ? 'bg-white text-black' 
          : 'text-neutral-500 hover:text-neutral-200'
      }`}
    >
      {code}
    </a>
  ))}
</div>
