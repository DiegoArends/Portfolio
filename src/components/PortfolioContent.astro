---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { projects as projectsData, experience as experienceData } from '../i18n/ui';
import avatar from "../assets/avatar.jpeg";
import face from "../assets/face.jpeg";
import cv from "../assets/Diego Arends CV.pdf";

const { lang } = Astro.props;
const t = useTranslations(lang);
const projects = projectsData[lang];
const experience = experienceData[lang];

const getImageSrc = (img: string | { src?: string }) => (typeof img === 'string' ? img : img?.src ?? '');
const badgeClass = (t: string) => {
  return "text-[11px] uppercase tracking-wider font-bold border border-neutral-800 bg-neutral-900/80 text-neutral-400 px-3 py-1.5 rounded-lg hover:border-sky-500/30 hover:text-white transition-all duration-300 shadow-sm";
};
---

<section class="pt-12 pb-20">
  <div class="flex items-center gap-4 mb-6">
    <img src={avatar.src} alt="Diego Arends" class="w-20 h-20 rounded-2xl rotate-3 border-2 border-neutral-800 shadow-2xl" />
    <div>
      <span class="text-sky-400 text-sm font-mono tracking-widest uppercase">{t('hero.available')}</span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tighter">Diego Arends</h1>
    </div>
  </div>
  
  <p class="text-xl text-neutral-400 max-w-2xl leading-relaxed">
    <span class="text-white">{t('hero.tagline')}</span> <Fragment set:html={t('hero.desc')} />
  </p>

  <div class="mt-10 flex flex-wrap gap-4">
    <a href="mailto:diegoarends17@gmail.com" class="bg-white text-black px-6 py-3 rounded-xl font-bold hover:bg-sky-400 transition-colors shadow-lg shadow-sky-500/10">
      {t('hero.contact')}
    </a>
    <a href={cv} download class="border border-neutral-800 text-white px-6 py-3 rounded-xl font-bold hover:bg-neutral-900 transition-all">
      {t('hero.cv')}
    </a>
  </div>
</section>

<section id="projects" class="py-20 border-t border-neutral-900">
  <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
    <span class="w-8 h-[2px] bg-sky-500"></span> {t('projects.title')}
  </h2>
  
  <div class="flex flex-wrap justify-center gap-10">
    {projects.map((p) => (
      <div class="group relative bg-neutral-900/40 backdrop-blur-sm border border-neutral-800/50 rounded-3xl overflow-hidden hover:border-sky-500/40 hover:shadow-2xl hover:shadow-sky-500/10 transition-all duration-500 flex flex-col w-full md:w-[calc(50%-1.25rem)]">
        <div class="aspect-video overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-t from-neutral-950/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 flex items-end p-6">
             {p.repo && (
               <a href={p.repo} target="_blank" class="text-white text-[10px] uppercase tracking-tight font-bold bg-neutral-900/90 px-4 py-2 rounded-xl border border-neutral-700 hover:bg-white hover:text-black transition-all">
                 {t('projects.view_code')}
               </a>
             )}
          </div>
          <img 
            src={getImageSrc(p.image)} 
            alt={p.title} 
            class="w-full h-full object-cover saturate-[0.8] group-hover:saturate-100 group-hover:scale-105 transition-all duration-700"
          />
        </div>
        <div class="p-8 flex-1 flex flex-col">
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-sky-400 transition-colors uppercase tracking-tight">{p.title}</h3>
          <p class="text-neutral-400 text-sm mb-8 line-clamp-3 leading-relaxed flex-1 italic">{p.description}</p>
          
          <div class="flex flex-wrap gap-2 mb-8">
            {p.stack.map(t => <span class={badgeClass(t)}>{t}</span>)}
          </div>

          <div class="flex items-center justify-between mt-auto pt-6 border-t border-neutral-800/50">
            <a href={p.link} target="_blank" class="inline-flex items-center gap-2 text-sky-400 text-sm font-bold hover:text-white transition-all group/link">
              {t('projects.explore')}
              <span class="group-hover/link:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<section id="experience" class="py-20 border-t border-neutral-900">
  <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
    <span class="w-8 h-[2px] bg-sky-500"></span> {t('experience.title')}
  </h2>
  
  <div class="space-y-12">
    {experience.map((exp, index) => (
      <div class="relative pl-8 border-l border-neutral-800 hover:border-sky-500/50 transition-colors">
        <div class={`absolute -left-[5px] top-0 w-2 h-2 rounded-full ${index === 0 ? 'bg-sky-500 shadow-[0_0_10px_rgba(56,189,248,0.5)]' : 'bg-neutral-800 group-hover:bg-sky-500'} transition-colors`}></div>
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-4">
          <div>
            <h3 class="text-xl font-bold text-white font-mono">{exp.role}</h3>
            <p class={`${index === 0 ? 'text-sky-400' : 'text-neutral-500'} font-medium`}>{exp.company}</p>
          </div>
          <span class="text-[10px] font-mono text-neutral-500 bg-neutral-900 border border-neutral-800 px-3 py-1 rounded-full uppercase">{exp.period}</span>
        </div>
        {Array.isArray(exp.description) ? (
          <ul class="space-y-3 text-neutral-400 text-sm">
            {exp.description.map(item => (
              <li class="flex gap-2">
                <span class="text-sky-500">•</span>
                <Fragment set:html={item} />
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-neutral-400 text-sm mb-4">{exp.description}</p>
        )}
        {exp.company === 'Freelance' && (
          <div class="flex flex-wrap gap-2">
            {['Drakon Insights', 'Squad Manager', 'GastonNetworks'].map(p => (
              <span class="text-[9px] uppercase tracking-tighter text-neutral-500 border border-neutral-800 px-2 py-0.5 rounded-md bg-neutral-900/50">{p}</span>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<section id="about" class="py-20 border-t border-neutral-900">
  <div class="grid md:grid-cols-2 gap-12 items-center">
    <div class="space-y-6">
      <h2 class="text-3xl font-bold text-white italic tracking-tight">{t('about.title')}</h2>
      <p class="text-neutral-400 leading-relaxed text-lg">
        <Fragment set:html={t('about.p1')} />
      </p>
      <p class="text-neutral-400 leading-relaxed">
        <Fragment set:html={t('about.p2')} />
      </p>
      
      <div class="flex flex-wrap gap-3 pt-4">
        {['JavaScript', 'TypeScript', 'React', 'Node.js', 'Tailwind', 'SQLite', 'Astro', 'Figma'].map(tech => (
          <span class={badgeClass(tech)}>
            {tech}
          </span>
        ))}
      </div>
    </div>
    
    <div class="relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-sky-500 to-indigo-500 rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
      <img 
        src={face.src} 
        alt="Diego Arends" 
        class="relative rounded-2xl border border-neutral-800 saturate-[0.8] brightness-[0.9] group-hover:saturate-100 group-hover:brightness-100 group-hover:scale-[1.03] transition-all duration-500 ease-out group-hover:shadow-[0_0_50px_-12px_rgba(56,189,248,0.3)]"
      />
    </div>
  </div>
</section>

<style>
  section {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
